# Use localhost when LM Studio runs on the same machine.
# In WSL + Windows setups, replace this with the Windows host IP if needed.
ADMIN_AI_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
ADMIN_AI_LMSTUDIO_API_KEY=lm-studio
ADMIN_AI_LLM_MODEL_NAME=llama-3.1-8b-instruct
ADMIN_AI_LLM_TEMPERATURE=0.1

# Multilingual embedding model recommended for Spanish-heavy legal corpora.
ADMIN_AI_EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base

ADMIN_AI_DOCUMENTS_DIR=./documents
ADMIN_AI_CHROMA_PATH=./chroma_db
ADMIN_AI_CHROMA_COLLECTION_NAME=auditoria_pymes
ADMIN_AI_MANIFEST_PATH=./chroma_db/ingestion_manifest.json

ADMIN_AI_CHUNK_SIZE=1024
ADMIN_AI_CHUNK_OVERLAP=100
ADMIN_AI_INGESTION_BACKEND=auto
ADMIN_AI_UNSTRUCTURED_CHUNK_CHARS=1800
ADMIN_AI_MAX_CITATIONS=6
ADMIN_AI_DEFAULT_QUERY=Provide an executive summary of this contract and list critical termination clauses and penalties.